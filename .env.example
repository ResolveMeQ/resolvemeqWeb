# API origin for marketing forms (newsletter + contact). Defaults: dev → http://localhost:8000, prod build → https://api.resolvemeq.net
# REACT_APP_API_ORIGIN=https://api.resolvemeq.net

# Optional overrides (full URLs; if unset, derived as {REACT_APP_API_ORIGIN}/api/subscribe and /api/contact)
# REACT_APP_SUBSCRIBE_API_URL=
# REACT_APP_CONTACT_API_URL=

# Optional: set true to disable POSTs (e.g. static demo with no backend)
# REACT_APP_MARKETING_API_DISABLED=true

# Optional: Formspree form ID for the CTA only when contact API is disabled (see subscribeContact.js)
REACT_APP_FORMSPREE_ID=
